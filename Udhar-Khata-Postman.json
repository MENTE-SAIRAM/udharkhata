    {
      "name": "Nudge",
      "item": [
        {
          "name": "Generate Nudge",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contactId\": \"{{contactId}}\",\n  \"style\": \"polite\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/nudge/generate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "nudge", "generate"]
            }
          }
        }
      ]
    },
    {
      "name": "Export (Premium)",
      "item": [
        {
          "name": "Export PDF",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/export/pdf?contactId={{contactId}}&from=2026-01-01&to=2026-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "export", "pdf"],
              "query": [
                { "key": "contactId", "value": "{{contactId}}" },
                { "key": "from", "value": "2026-01-01" },
                { "key": "to", "value": "2026-12-31" }
              ]
            }
          }
        },
        {
          "name": "Export CSV",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/export/csv?contactId={{contactId}}&from=2026-01-01&to=2026-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "export", "csv"],
              "query": [
                { "key": "contactId", "value": "{{contactId}}" },
                { "key": "from", "value": "2026-01-01" },
                { "key": "to", "value": "2026-12-31" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notifications"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Mark All Read",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications/read-all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notifications", "read-all"]
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "health"]
            }
          }
        }
      ]
    }
  ]
}
